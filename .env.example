# Провайдер: openai (по умолчанию) или gemini
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-5.4-nano

# Gemini (если AI_PROVIDER=gemini)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

PORT=3001

# Опционально: URL API, если фронт и бэкенд на разных доменах
# VITE_API_URL=https://your-api.example.com/api/generate
