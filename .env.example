# Провайдер: grok (xAI / Groq), openai или gemini
AI_PROVIDER=grok

# Grok — ключ вводится в Game Studio (Groq gsk_... или xAI xai-...)
# Опционально для dev без UI: GROK_API_KEY=gsk_your-key-here
# GROK_MODEL=llama-3.3-70b-versatile   # для gsk_ (Groq)
# GROK_MODEL=grok-3-fast                 # для xai- (xAI)

# ChatGPT
# OPENAI_API_KEY=sk-proj-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

PORT=3001
