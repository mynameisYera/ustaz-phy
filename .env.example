# OpenAI
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-5.4-nano

# RAG / File Search — күрделі модель (nano нашар іздейді)
OPENAI_RAG_MODEL=gpt-4o-mini

# RAG — Vector Store (опционально, иначе создаётся через RAG Playground)
# OPENAI_VECTOR_STORE_ID=vs_abc123xyz456
# OPENAI_VECTOR_STORE_NAME=Mektep kitaptary

PORT=3001

# Опционально: URL API, если фронт и бэкенд на разных доменах
# VITE_API_URL=https://your-api.example.com/api/generate
