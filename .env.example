# Провайдер: openai (ChatGPT) или gemini
AI_PROVIDER=openai

# ChatGPT — ключ начинается с sk-proj- или sk-
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Gemini (альтернатива, бесплатно)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

PORT=3001
